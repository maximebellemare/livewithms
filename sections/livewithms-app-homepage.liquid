{% liquid
  assign hero_badge = section.settings.hero_badge | default: 'Daily support for life with MS'
  assign app_store_url = section.settings.app_store_url | default: '#'
  assign google_play_url = section.settings.google_play_url | default: '#'
%}

<section class="lwm-homepage" id="livewithms-homepage-{{ section.id }}">
  <style>
    #shopify-section-{{ section.id }} {
      --lwm-orange: #fe781a;
      --lwm-orange-deep: #cf5d08;
      --lwm-orange-soft: #fff3e9;
      --lwm-orange-wash: #fff8f3;
      --lwm-cream: #fffdfb;
      --lwm-ink: #172033;
      --lwm-copy: #5f6778;
      --lwm-line: rgba(23, 32, 51, 0.1);
      --lwm-shadow: 0 28px 60px rgba(23, 32, 51, 0.12);
      --lwm-shadow-soft: 0 16px 38px rgba(23, 32, 51, 0.08);
      color: var(--lwm-ink);
    }

    #shopify-section-{{ section.id }} .lwm-homepage,
    #shopify-section-{{ section.id }} .lwm-homepage * {
      box-sizing: border-box;
    }

    #shopify-section-{{ section.id }} .lwm-shell {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 20px 88px;
    }

    #shopify-section-{{ section.id }} .lwm-stack {
      display: grid;
      gap: 28px;
      padding-top: 26px;
    }

    #shopify-section-{{ section.id }} .lwm-card,
    #shopify-section-{{ section.id }} .lwm-hero,
    #shopify-section-{{ section.id }} .lwm-final-cta,
    #shopify-section-{{ section.id }} .lwm-faq {
      position: relative;
      overflow: hidden;
      border-radius: 30px;
      background: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.65);
      box-shadow: var(--lwm-shadow-soft);
    }

    #shopify-section-{{ section.id }} .lwm-hero {
      background:
        radial-gradient(circle at top right, rgba(255, 255, 255, 0.34), transparent 34%),
        radial-gradient(circle at bottom left, rgba(255, 232, 215, 0.28), transparent 28%),
        linear-gradient(135deg, #ff9450 0%, #fe781a 48%, #de650c 100%);
      color: #ffffff;
      box-shadow: 0 34px 70px rgba(159, 67, 0, 0.24);
    }

    #shopify-section-{{ section.id }} .lwm-hero-grid,
    #shopify-section-{{ section.id }} .lwm-section,
    #shopify-section-{{ section.id }} .lwm-faq-inner,
    #shopify-section-{{ section.id }} .lwm-final-grid {
      padding: 32px;
    }

    #shopify-section-{{ section.id }} .lwm-hero-grid {
      display: grid;
      gap: 28px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .lwm-copy-stack,
    #shopify-section-{{ section.id }} .lwm-section-heading,
    #shopify-section-{{ section.id }} .lwm-proof-list,
    #shopify-section-{{ section.id }} .lwm-feature-copy,
    #shopify-section-{{ section.id }} .lwm-value-copy,
    #shopify-section-{{ section.id }} .lwm-final-copy {
      display: grid;
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .lwm-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      width: fit-content;
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      border: 1px solid rgba(255, 255, 255, 0.25);
      font-size: 1.08rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .lwm-eyebrow::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #ffffff;
      box-shadow: 0 0 0 6px rgba(255, 255, 255, 0.12);
    }

    #shopify-section-{{ section.id }} .lwm-homepage h1,
    #shopify-section-{{ section.id }} .lwm-homepage h2,
    #shopify-section-{{ section.id }} .lwm-homepage h3,
    #shopify-section-{{ section.id }} .lwm-homepage h4,
    #shopify-section-{{ section.id }} .lwm-homepage p {
      margin: 0;
      font: inherit;
    }

    #shopify-section-{{ section.id }} .lwm-homepage h1,
    #shopify-section-{{ section.id }} .lwm-homepage h2,
    #shopify-section-{{ section.id }} .lwm-homepage h3,
    #shopify-section-{{ section.id }} .lwm-homepage h4 {
      color: inherit;
      letter-spacing: -0.03em;
      line-height: 1.04;
      font-weight: 800;
    }

    #shopify-section-{{ section.id }} .lwm-homepage h1 {
      font-size: clamp(3rem, 5.6vw, 5.8rem);
      max-width: 10.5ch;
    }

    #shopify-section-{{ section.id }} .lwm-homepage h2 {
      font-size: clamp(2.2rem, 4vw, 3.6rem);
      color: var(--lwm-ink);
    }

    #shopify-section-{{ section.id }} .lwm-homepage h3 {
      font-size: clamp(1.55rem, 2vw, 2.15rem);
      color: var(--lwm-ink);
    }

    #shopify-section-{{ section.id }} .lwm-lead {
      max-width: 60ch;
      font-size: 1.54rem;
      line-height: 1.74;
      color: rgba(255, 255, 255, 0.92);
    }

    #shopify-section-{{ section.id }} .lwm-copy,
    #shopify-section-{{ section.id }} .lwm-faq-answer,
    #shopify-section-{{ section.id }} .lwm-disclaimer,
    #shopify-section-{{ section.id }} .lwm-section-heading p,
    #shopify-section-{{ section.id }} .lwm-feature-copy p,
    #shopify-section-{{ section.id }} .lwm-value-copy p,
    #shopify-section-{{ section.id }} .lwm-final-copy p {
      color: var(--lwm-copy);
      line-height: 1.74;
      font-size: 1.56rem;
    }

    #shopify-section-{{ section.id }} .lwm-hero-note {
      font-size: 1.42rem;
      line-height: 1.72;
      color: rgba(255, 255, 255, 0.78);
      max-width: 55ch;
    }

    #shopify-section-{{ section.id }} .lwm-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .lwm-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 60px;
      padding: 16px 24px;
      border-radius: 18px;
      text-decoration: none;
      font-weight: 700;
      font-size: 1.08rem;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease;
    }

    #shopify-section-{{ section.id }} .lwm-button:hover,
    #shopify-section-{{ section.id }} .lwm-button:focus {
      transform: translateY(-1px);
    }

    #shopify-section-{{ section.id }} .lwm-button-primary {
      background: #ffffff;
      color: var(--lwm-orange-deep);
      box-shadow: 0 16px 30px rgba(106, 36, 0, 0.18);
    }

    #shopify-section-{{ section.id }} .lwm-button-secondary {
      background: rgba(255, 255, 255, 0.12);
      color: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.28);
    }

    #shopify-section-{{ section.id }} .lwm-button-solid {
      background: var(--lwm-orange);
      color: #ffffff;
      box-shadow: 0 18px 32px rgba(254, 120, 26, 0.24);
    }

    #shopify-section-{{ section.id }} .lwm-button-outline {
      background: #ffffff;
      color: var(--lwm-orange-deep);
      border: 1px solid rgba(254, 120, 26, 0.2);
    }

    #shopify-section-{{ section.id }} .lwm-hero-visual {
      display: grid;
      gap: 12px;
      align-content: center;
    }

    #shopify-section-{{ section.id }} .lwm-collage {
      display: grid;
      grid-template-columns: minmax(0, 0.88fr) minmax(0, 0.64fr);
      gap: 12px;
      align-items: end;
    }

    #shopify-section-{{ section.id }} .lwm-shot,
    #shopify-section-{{ section.id }} .lwm-gallery-shot {
      position: relative;
      border-radius: 30px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.22);
      box-shadow: 0 24px 48px rgba(97, 38, 0, 0.18);
      min-height: 128px;
    }

    #shopify-section-{{ section.id }} .lwm-shot img,
    #shopify-section-{{ section.id }} .lwm-gallery-shot img,
    #shopify-section-{{ section.id }} .lwm-story-shot img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .lwm-shot--tall {
      min-height: 220px;
    }

    #shopify-section-{{ section.id }} .lwm-shot--small {
      min-height: 102px;
    }

    #shopify-section-{{ section.id }} .lwm-shot-fallback,
    #shopify-section-{{ section.id }} .lwm-story-fallback,
    #shopify-section-{{ section.id }} .lwm-gallery-fallback {
      height: 100%;
      width: 100%;
      display: grid;
      place-items: center;
      padding: 20px;
      text-align: center;
      line-height: 1.5;
    }

    #shopify-section-{{ section.id }} .lwm-shot-fallback {
      color: rgba(255, 255, 255, 0.88);
      background:
        radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 28%),
        linear-gradient(160deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.06));
    }

    #shopify-section-{{ section.id }} .lwm-proof-list {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .lwm-proof {
      display: grid;
      gap: 10px;
      padding: 22px 22px 20px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.22);
    }

    #shopify-section-{{ section.id }} .lwm-proof strong {
      font-size: 1.38rem;
      font-weight: 800;
    }

    #shopify-section-{{ section.id }} .lwm-proof span {
      color: rgba(255, 255, 255, 0.82);
      line-height: 1.72;
      font-size: 1.34rem;
    }

    #shopify-section-{{ section.id }} .lwm-section-heading {
      margin-bottom: 28px;
      max-width: 760px;
    }

    #shopify-section-{{ section.id }} .lwm-section-heading--center {
      text-align: center;
      max-width: 820px;
      margin-left: auto;
      margin-right: auto;
    }

    #shopify-section-{{ section.id }} .lwm-value-grid,
    #shopify-section-{{ section.id }} .lwm-story-grid,
    #shopify-section-{{ section.id }} .lwm-feature-grid,
    #shopify-section-{{ section.id }} .lwm-gallery-grid,
    #shopify-section-{{ section.id }} .lwm-faq-grid {
      display: grid;
      gap: 22px;
    }

    #shopify-section-{{ section.id }} .lwm-value-card,
    #shopify-section-{{ section.id }} .lwm-story-card,
    #shopify-section-{{ section.id }} .lwm-feature-card,
    #shopify-section-{{ section.id }} .lwm-gallery-card,
    #shopify-section-{{ section.id }} .lwm-faq-item {
      background: #ffffff;
      border-radius: 26px;
      border: 1px solid var(--lwm-line);
      box-shadow: var(--lwm-shadow-soft);
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .lwm-value-card,
    #shopify-section-{{ section.id }} .lwm-feature-card {
      padding: 32px;
    }

    #shopify-section-{{ section.id }} .lwm-value-kicker,
    #shopify-section-{{ section.id }} .lwm-story-kicker,
    #shopify-section-{{ section.id }} .lwm-feature-kicker {
      color: var(--lwm-orange-deep);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 1.14rem;
      font-weight: 800;
    }

    #shopify-section-{{ section.id }} .lwm-story-card {
      display: grid;
      gap: 0;
      background: linear-gradient(180deg, #fffdfa 0%, #ffffff 100%);
    }

    #shopify-section-{{ section.id }} .lwm-story-shot {
      min-height: 142px;
      background: var(--lwm-orange-wash);
    }

    #shopify-section-{{ section.id }} .lwm-story-copy {
      padding: 30px;
      display: grid;
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .lwm-story-fallback,
    #shopify-section-{{ section.id }} .lwm-gallery-fallback {
      background: linear-gradient(180deg, #fffaf6 0%, #fff1e5 100%);
      color: var(--lwm-ink);
    }

    #shopify-section-{{ section.id }} .lwm-feature-grid {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .lwm-feature-card {
      display: grid;
      gap: 14px;
      background: linear-gradient(180deg, #ffffff 0%, #fffdfa 100%);
    }

    #shopify-section-{{ section.id }} .lwm-feature-icon {
      width: 54px;
      height: 54px;
      display: grid;
      place-items: center;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(254, 120, 26, 0.16), rgba(254, 120, 26, 0.06));
      border: 1px solid rgba(254, 120, 26, 0.14);
      color: var(--lwm-orange-deep);
      font-weight: 800;
      font-size: 1.15rem;
    }

    #shopify-section-{{ section.id }} .lwm-gallery-card {
      display: grid;
      gap: 0;
    }

    #shopify-section-{{ section.id }} .lwm-gallery-shot {
      min-height: 150px;
      background: var(--lwm-orange-wash);
      box-shadow: none;
      border: 0;
      border-bottom: 1px solid var(--lwm-line);
      border-radius: 0;
    }

    #shopify-section-{{ section.id }} .lwm-gallery-copy {
      padding: 24px;
      display: grid;
      gap: 14px;
    }

    #shopify-section-{{ section.id }} .lwm-gallery-copy h3 {
      font-size: 1.62rem;
    }

    #shopify-section-{{ section.id }} .lwm-faq-inner {
      display: grid;
      gap: 26px;
    }

    #shopify-section-{{ section.id }} .lwm-faq-item {
      padding: 24px;
    }

    #shopify-section-{{ section.id }} .lwm-faq-item h3 {
      margin-bottom: 10px;
      font-size: 1.26rem;
      color: var(--lwm-ink);
    }

    #shopify-section-{{ section.id }} .lwm-final-cta {
      background:
        radial-gradient(circle at top right, rgba(254, 120, 26, 0.12), transparent 30%),
        linear-gradient(180deg, #fffaf6 0%, #ffffff 100%);
    }

    #shopify-section-{{ section.id }} .lwm-final-grid {
      display: grid;
      gap: 20px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .lwm-disclaimer {
      padding: 0 8px;
      font-size: 1.3rem;
      color: #6a7282;
    }

    #shopify-section-{{ section.id }} .lwm-cta-inline {
      display: grid;
      gap: 18px;
      align-items: center;
      justify-items: start;
      margin-top: 18px;
    }

    #shopify-section-{{ section.id }} .lwm-cta-inline--center {
      justify-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .lwm-arrow-note {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--lwm-orange-deep);
      font-size: 1.38rem;
      font-weight: 800;
      line-height: 1.4;
      animation: lwm-arrow-bounce 1.35s ease-in-out infinite;
    }

    #shopify-section-{{ section.id }} .lwm-arrow-note::before {
      content: "➜";
      color: var(--lwm-orange);
      font-size: 1.95rem;
      line-height: 1;
      display: inline-block;
      animation: lwm-arrow-point 1.35s ease-in-out infinite;
    }

    @keyframes lwm-arrow-bounce {
      0%, 100% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(6px);
      }
    }

    @keyframes lwm-arrow-point {
      0%, 100% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(8px);
      }
    }

    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .lwm-shell {
        padding-left: 24px;
        padding-right: 24px;
      }

      #shopify-section-{{ section.id }} .lwm-stack {
        gap: 38px;
        padding-top: 34px;
      }

      #shopify-section-{{ section.id }} .lwm-hero-grid,
      #shopify-section-{{ section.id }} .lwm-section,
      #shopify-section-{{ section.id }} .lwm-faq-inner,
      #shopify-section-{{ section.id }} .lwm-final-grid {
        padding: 46px;
      }

      #shopify-section-{{ section.id }} .lwm-proof-list,
      #shopify-section-{{ section.id }} .lwm-value-grid,
      #shopify-section-{{ section.id }} .lwm-gallery-grid,
      #shopify-section-{{ section.id }} .lwm-faq-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .lwm-story-grid,
      #shopify-section-{{ section.id }} .lwm-feature-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media screen and (min-width: 990px) {
      #shopify-section-{{ section.id }} .lwm-hero-grid {
        grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
        gap: 42px;
        padding: 54px;
      }

      #shopify-section-{{ section.id }} .lwm-cta-inline {
        grid-auto-flow: column;
        justify-content: start;
      }

      #shopify-section-{{ section.id }} .lwm-cta-inline--center {
        grid-auto-flow: row;
        justify-content: center;
      }

      #shopify-section-{{ section.id }} .lwm-proof-list {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .lwm-value-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .lwm-story-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .lwm-feature-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .lwm-gallery-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      #shopify-section-{{ section.id }} .lwm-final-grid {
        grid-template-columns: minmax(0, 1fr) auto;
      }
    }
  </style>

  <div class="lwm-shell">
    <div class="lwm-stack">
      <div class="lwm-hero">
        <div class="lwm-hero-grid">
          <div class="lwm-copy-stack">
            <span class="lwm-eyebrow">{{ hero_badge }}</span>
            <h1>Daily MS support that helps life feel more manageable.</h1>
            <p class="lwm-lead">
              Track symptoms, protect energy, organize appointments and medications, use AI-guided support, and build calmer routines in one beautifully simple app.
            </p>
            <div class="lwm-actions">
              <a class="lwm-button lwm-button-primary" href="{{ app_store_url }}">Download on the App Store</a>
              <a class="lwm-button lwm-button-secondary" href="{{ google_play_url }}">Get it on Google Play</a>
            </div>
            <p class="lwm-hero-note">
              Created for people living with MS who want clearer daily support, better organization, and more confidence in what to do next. Not a replacement for medical care.
            </p>

            <div class="lwm-proof-list">
              <div class="lwm-proof">
                <strong>One calm home base</strong>
                <span>Check-ins, planning, nutrition, support tools, and community in one place.</span>
              </div>
              <div class="lwm-proof">
                <strong>Designed for real energy limits</strong>
                <span>Short flows, gentle structure, and less friction on hard days.</span>
              </div>
              <div class="lwm-proof">
                <strong>Built to help you notice patterns</strong>
                <span>See what may be changing over time without turning life into spreadsheets.</span>
              </div>
            </div>
          </div>

          <div class="lwm-hero-visual" aria-label="LiveWithMS app screenshots">
            <div class="lwm-collage">
              <div class="lwm-shot lwm-shot--tall">
                {% if section.settings.hero_primary_image != blank %}
                  {{
                    section.settings.hero_primary_image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      widths: '360, 540, 720, 900',
                      sizes: '(min-width: 990px) 34vw, 100vw'
                  }}
                {% else %}
                  <div class="lwm-shot-fallback">
                    Upload a strong Today or Coach screen here for the main hero screenshot.
                  </div>
                {% endif %}
              </div>
              <div class="lwm-shot lwm-shot--small">
                {% if section.settings.hero_secondary_image != blank %}
                  {{
                    section.settings.hero_secondary_image
                    | image_url: width: 700
                    | image_tag:
                      loading: 'lazy',
                      widths: '280, 420, 560, 700',
                      sizes: '(min-width: 990px) 24vw, 45vw'
                  }}
                {% else %}
                  <div class="lwm-shot-fallback">
                    Upload a second supporting screenshot here.
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="lwm-card">
        <div class="lwm-section">
          <div class="lwm-section-heading lwm-section-heading--center">
            <h2>MS can make simple decisions feel heavier than they should.</h2>
            <p>
              LiveWithMS gives you one place to check in, stay organized, and move through the day with more clarity. Instead of juggling symptoms, routines, food decisions, appointments, and mental overload separately, the app helps bring them together in a calmer way.
            </p>
          </div>

          <div class="lwm-value-grid">
            <article class="lwm-value-card">
              <div class="lwm-value-copy">
                <span class="lwm-value-kicker">Less mental clutter</span>
                <h3>Know what needs your attention today.</h3>
                <p>Daily check-ins, logistics, and planning prompts help reduce the “where do I even start?” feeling.</p>
              </div>
            </article>
            <article class="lwm-value-card">
              <div class="lwm-value-copy">
                <span class="lwm-value-kicker">More useful reflection</span>
                <h3>See patterns without needing to overthink every entry.</h3>
                <p>Track symptoms, sleep, mood, stress, and hydration, then review clear summaries that stay cautious and readable.</p>
              </div>
            </article>
            <article class="lwm-value-card">
              <div class="lwm-value-copy">
                <span class="lwm-value-kicker">Support that fits real life</span>
                <h3>Use practical tools when the day feels harder.</h3>
                <p>Coach, nutrition support, brain games, care planning, and community are there when you need structure, not noise.</p>
              </div>
            </article>
          </div>
        </div>
      </div>

      <div class="lwm-card">
        <div class="lwm-section">
          <div class="lwm-section-heading">
            <h2>The app is built around how support actually needs to feel.</h2>
            <p>
              Clean, warm, and highly usable on a difficult day. Every screen is designed to help you act faster, think less, and stay connected to what matters.
            </p>
            <div class="lwm-cta-inline">
              <span class="lwm-arrow-note">Download here when you are ready to start.</span>
