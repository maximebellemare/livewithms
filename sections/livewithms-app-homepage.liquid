      {% if section.settings.show_disclaimer %}
        <p class="lwm-disclaimer">
          LiveWithMS is for education, reflection, organization, and daily support. It does not diagnose, treat, cure, or prevent any disease and does not replace medical advice, diagnosis, or treatment from a qualified healthcare professional.
        </p>
      {% endif %}
