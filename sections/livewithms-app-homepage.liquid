      "default": "Daily support for life with MS"
    },
    {
      "type": "text",
      "id": "app_store_url",
      "label": "App Store URL",
      "default": "https://apps.apple.com/"
    },
    {
      "type": "text",
      "id": "google_play_url",
      "label": "Google Play URL",
      "default": "https://play.google.com/store"
    },
    {
      "type": "image_picker",
      "id": "hero_primary_image",
      "label": "Hero primary screenshot"
    },
    {
      "type": "image_picker",
      "id": "hero_secondary_image",
      "label": "Hero secondary screenshot"
    },
    {
      "type": "image_picker",
      "id": "today_image",
      "label": "Today screenshot"
    },
    {
      "type": "image_picker",
      "id": "track_image",
      "label": "Track screenshot"
    },
    {
      "type": "image_picker",
      "id": "coach_image",
      "label": "Coach screenshot"
    },
    {
      "type": "image_picker",
      "id": "care_image",
      "label": "Care or Nutrition screenshot"
    },
    {
      "type": "image_picker",
      "id": "programs_image",
      "label": "Programs screenshot"
    },
    {
      "type": "image_picker",
      "id": "community_image",
      "label": "Community screenshot"
    },
    {
      "type": "image_picker",
      "id": "profile_image",
      "label": "Profile screenshot"
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Show disclaimer",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "LiveWithMS App Homepage"
    }
  ]
}
